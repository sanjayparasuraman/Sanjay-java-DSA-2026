class Solution {
    public int maxProfit(int[] prices) {
        int ans = 0;
        int min =Integer.MAX_VALUE;
        int temp = 0;

        for(int i=0;i<prices.length;i++){
            if(prices[i]<min){
                min = prices[i];
            }

            temp = prices[i]-min;
            if(ans<temp){
                ans = temp;
            }
        }
        return ans;
        //121
    }
}